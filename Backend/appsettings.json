{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=appdb;Username=myuser;Password=mypassword"
  },
  "Gemini": {
    "ApiKey": "ReplaceWithYourGeminiApiKey"
  },
  "Jieba": {
    "DictPath": "/tmp/jieba_user_dict.txt"
  },
  "RateLimit": {
    "DailyLimit": 100,
    "AllowedIps": [ "127.0.0.1", "::1" ]
  }
}
